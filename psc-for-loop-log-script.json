{
  "sleep": "0",
  "name": "For Loop Log Test",
  "version": 1.0,
  "actions": [
    {
      "id": "FOR_EACH_NUMBER_IN_RANGE",
      "properties": {
        "Minimum": "1",
        "Maximum": "101"
      },
      "children": [
        {
          "id": "SET_VARIABLE_TO_LAST_OUTPUT",
          "properties": {
            "Variable name": "loopNumber"
          },
          "children": [
            {
              "id": "LOG",
              "properties": {
                "Message": "v(loopNumber)"
              }
            }
          ]
        }
      ]
    }
  ]
}
