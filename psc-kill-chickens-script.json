{
  "sleep": "0",
  "name": "Kill Chickens",
  "version": 1.0,
  "actions": [
    {
      "id": "COMMENT",
      "properties": {
        "Comment": "If no chickens are available, walk to the Lumbridge chicken coop"
      }
    },
    {
      "id": "IF_NPC_DOES_NOT_EXIST",
      "properties": {
        "Filter NPC By": {
          "class": "NPC",
          "logic": "NONE",
          "type": "NAME",
          "operator": "EQUALS",
          "value": "Chicken"
        }
      },
      "children": [
        {
          "id": "WALK_TO_AREA",
          "properties": {
            "Area": "(3225, 3295, 0), (3236, 3303, 0)"
          }
        }
      ]
    },
    {
      "id": "COMMENT",
      "properties": {
        "Comment": "Clear target if the stored chicken no longer exists"
      }
    },
    {
      "id": "IF_VARIABLE_IS_SET",
      "properties": {
        "Variable name": "npcTarget"
      },
      "children": [
        {
          "id": "IF_NPC_DOES_NOT_EXIST",
          "properties": {
            "Filter NPC By": {
              "class": "NPC",
              "logic": "NONE",
              "type": "IS_VARIABLE_VALUE",
              "operator": "EQUALS",
              "value": "npcTarget"
            }
          },
          "children": [
            {
              "id": "DELETE_VARIABLE",
              "properties": {
                "Variable name": "npcTarget"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "COMMENT",
      "properties": {
        "Comment": "If a chicken exists and there is no target, set one"
      }
    },
    {
      "id": "IF_VARIABLE_IS_NOT_SET",
      "properties": {
        "Variable name": "npcTarget"
      },
      "children": [
        {
          "id": "IF_NPC_EXISTS",
          "properties": {
            "Filter NPC By": {
              "class": "NPC",
              "logic": "NONE",
              "type": "NAME",
              "operator": "EQUALS",
              "value": "Chicken",
              "filters": [
                {
                  "class": "NPC",
                  "logic": "AND",
                  "type": "IS_HEALTH_BAR_NOT_VISIBLE",
                  "operator": "EQUALS"
                },
                {
                  "class": "NPC",
                  "logic": "AND",
                  "type": "WALKING_DISTANCE_TO_PLAYER",
                  "operator": "LESS_THAN",
                  "value": "20"
                }
              ]
            }
          },
          "children": [
            {
              "id": "SET_VARIABLE_TO_LAST_OUTPUT",
              "properties": {
                "Variable name": "npcTarget"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "COMMENT",
      "properties": {
        "Comment": "Attack the current chicken target"
      }
    },
    {
      "id": "IF_NPC_EXISTS",
      "properties": {
        "Filter NPC By": {
          "class": "NPC",
          "logic": "NONE",
          "type": "IS_VARIABLE_VALUE",
          "operator": "EQUALS",
          "value": "npcTarget"
        }
      },
      "children": [
        {
          "id": "NPC_INTERACT",
          "properties": {
            "Filter NPC By": {
              "class": "NPC",
              "logic": "NONE",
              "type": "IS_VARIABLE_VALUE",
              "operator": "EQUALS",
              "value": "npcTarget"
            },
            "Action": "Attack"
          }
        }
      ]
    }
  ]
}
